# ============================================================
# Pupillo — Esempio variabili d'ambiente
# Copia in `.env` e compila i valori. NON committare `.env`.
# In Lovable Cloud questi valori sono iniettati automaticamente.
# ============================================================

# --- Supabase (client, esposte al browser) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Supabase (server-side / server functions) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (pagamenti, crediti, abbonamenti) ---
# Sandbox
STRIPE_SECRET_KEY_SANDBOX=
STRIPE_WEBHOOK_SECRET_SANDBOX=
# Live
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_SECRET_LIVE=

# --- Lovable AI Gateway (assistente, classificazioni) ---
LOVABLE_API_KEY=

# --- Verifica telefono / OTP (opzionale, se attivo) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# --- Geocoding / mappe (opzionale) ---
# MAPBOX_TOKEN=

# Nota: in produzione su Lovable Cloud, i segreti vanno aggiunti
# tramite il pannello Secrets, non in questo file.